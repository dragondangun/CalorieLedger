<UserControl
    x:Class="CalorieLedger.Views.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CalorieLedger.ViewModels"
    x:DataType="vm:MainViewModel">

  <ScrollViewer>
    <StackPanel Spacing="16" Margin="20">

      <TextBlock
          Text="Сегодня"
          FontSize="28"
          FontWeight="Bold" />

      <Border
          Padding="16"
          CornerRadius="16"
          BorderThickness="1">
        <StackPanel Spacing="8">
          <TextBlock
              Text="Калории"
              FontSize="18"
              FontWeight="SemiBold" />

          <TextBlock
              Text="{Binding Today.CaloriesSummary}"
              FontSize="24"
              FontWeight="Bold" />

          <TextBlock
              Text="{Binding Today.RemainingCaloriesSummary}"
              FontSize="16" />
        </StackPanel>
      </Border>

      <Border
          Padding="16"
          CornerRadius="16"
          BorderThickness="1">
        <StackPanel Spacing="8">
          <TextBlock
              Text="КБЖУ"
              FontSize="18"
              FontWeight="SemiBold" />

          <TextBlock
              Text="{Binding Today.MacrosSummary}"
              FontSize="18" />
        </StackPanel>
      </Border>

      <Button
          Content="Добавить еду"
          Command="{Binding Today.AddSampleFoodCommand}"
          HorizontalAlignment="Stretch" />

      <Button
          Content="Обожрался"
          HorizontalAlignment="Stretch" />

    </StackPanel>
  </ScrollViewer>
</UserControl>