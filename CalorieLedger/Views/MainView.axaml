<UserControl
    x:Class="CalorieLedger.Views.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CalorieLedger.ViewModels"
    xmlns:todayVm="using:CalorieLedger.ViewModels.Today"
    x:DataType="vm:MainViewModel">

  <ScrollViewer>
    <StackPanel Spacing="16" Margin="20">

      <TextBlock
          Text="Сегодня"
          FontSize="28"
          FontWeight="Bold" />

      <Border
          Padding="16"
          CornerRadius="16"
          BorderThickness="1">
        <StackPanel Spacing="8">
          <TextBlock
              Text="Калории"
              FontSize="18"
              FontWeight="SemiBold" />

          <TextBlock
              Text="{Binding Today.CaloriesSummary}"
              FontSize="24"
              FontWeight="Bold" />

          <TextBlock
              Text="{Binding Today.RemainingCaloriesSummary}"
              FontSize="16" />
        </StackPanel>
      </Border>

      <Border
          Padding="16"
          CornerRadius="16"
          BorderThickness="1">
        <StackPanel Spacing="8">
          <TextBlock
              Text="КБЖУ"
              FontSize="18"
              FontWeight="SemiBold" />

          <TextBlock
              Text="{Binding Today.MacrosSummary}"
              FontSize="18" />
        </StackPanel>
      </Border>

      <Button
          Content="Добавить еду"
          Command="{Binding Today.AddSampleFoodCommand}"
          HorizontalAlignment="Stretch" />

      <Button
          Content="Обожрался"
          Command="{Binding Today.MarkOvereatingCommand}"
          HorizontalAlignment="Stretch" />

      <Border
          Padding="16"
          CornerRadius="16"
          BorderThickness="1">
              <StackPanel Spacing="12">
                <TextBlock
                    Text="Съедено сегодня"
                    FontSize="18"
                    FontWeight="SemiBold" />

                <ItemsControl ItemsSource="{Binding Today.FoodItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="todayVm:TodayFoodLogItemViewModel">
                      <Border
                          Padding="10"
                          Margin="0,0,0,8"
                          BorderThickness="1"
                          CornerRadius="10">
                        <StackPanel Spacing="4">
                          <TextBlock
                              Text="{Binding Name}"
                              FontWeight="SemiBold" />

                          <TextBlock
                              Text="{Binding QuantitySummary}" />

                          <TextBlock
                              Text="{Binding CaloriesSummary}" />

                          <TextBlock
                              Text="{Binding MacrosSummary}" />

                          <TextBlock
                              Text="{Binding AccuracySummary}"
                              FontStyle="Italic"
                              Opacity="0.75" />
                          
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>